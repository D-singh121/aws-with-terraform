# Local .terraform directories
**/.terraform/*

# Terraform lock file (commit this if you want consistent provider versions)
# .terraform.lock.hcl

# State files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Sensitive variable files — never commit
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files (contain sensitive data)
*.tfplan
*.plan

# Terragrunt cache
.terragrunt-cache/

# SSH keys
*.pem
*.key

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo